{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["react", "react-dom"],
    "baseUrl": ".",
    "paths": {
      "@pi-apex/sdk": ["../../sdk/src/index.ts"],
      "@pi-apex/react-sdk": ["../../react-sdk/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
