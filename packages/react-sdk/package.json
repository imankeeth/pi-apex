{
  "name": "@pi-apex/react-sdk",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "prebuild": "npm run build --workspace=@pi-apex/sdk",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "watch": "tsc --watch"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@pi-apex/sdk": "file:../sdk",
    "@pi-apex/types": "file:../types"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "typescript": "^5.9.3"
  }
}
